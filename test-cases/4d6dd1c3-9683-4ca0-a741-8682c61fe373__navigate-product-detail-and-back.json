{
  "id": "navigate-product-detail-and-back",
  "testPlanId": "4d6dd1c3-9683-4ca0-a741-8682c61fe373",
  "requirementId": "95189b32-dab8-4545-8dbf-ce2e26c011c0",
  "suiteName": "sauce-demo-product-listing-smoke",
  "case": {
    "id": "navigate-product-detail-and-back",
    "title": "Navigate to product detail page and back to product listing",
    "priority": "P0",
    "platforms": [
      "chrome",
      "firefox",
      "safari",
      "edge"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step-1",
        "action": "openUrl",
        "targetDescription": "Navigate to Sauce Demo login page",
        "locatorHint": "https://www.saucedemo.com/",
        "value": "https://www.saucedemo.com/"
      },
      {
        "id": "step-2",
        "action": "fill",
        "targetDescription": "Enter username",
        "locatorHint": "[data-test='username']",
        "value": "standard_user"
      },
      {
        "id": "step-3",
        "action": "fill",
        "targetDescription": "Enter password",
        "locatorHint": "[data-test='password']",
        "value": "secret_sauce"
      },
      {
        "id": "step-4",
        "action": "tap",
        "targetDescription": "Click login button",
        "locatorHint": "[data-test='login-button']"
      },
      {
        "id": "step-5",
        "action": "tap",
        "targetDescription": "Click on Sauce Labs Backpack product name",
        "locatorHint": "[data-test='item-name-sauce-labs-backpack']"
      },
      {
        "id": "step-6",
        "action": "assertVisible",
        "targetDescription": "Verify product detail page is displayed",
        "locatorHint": ".inventory_details"
      },
      {
        "id": "step-7",
        "action": "tap",
        "targetDescription": "Click back to products button",
        "locatorHint": "[data-test='back-to-products']"
      },
      {
        "id": "step-8",
        "action": "assertVisible",
        "targetDescription": "Verify inventory page is displayed again",
        "locatorHint": ".inventory_list"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
